    "lucide-react": "^1.16.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.75.0",
    "react-router-dom": "^6.30.3",
    "recharts": "^3.8.0",
    "sonner": "^2.0.7",
